{
  "expo": {
    "name": "ChatApp",
    "slug": "chatbot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "chatbot",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.chatapp.app",
      "supportsTablet": false,
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to take photos and videos to share in chat.",
        "NSPhotoLibraryUsageDescription": "Photo library access is needed to share images and videos in chat.",
        "NSPhotoLibraryAddUsageDescription": "Allow ChatApp to save media to your photo library.",
        "NSMicrophoneUsageDescription": "Microphone access is needed to record audio messages."
      }
    },
    "android": {
      "package": "com.chatapp.app",
      "adaptiveIcon": {
        "backgroundColor": "#4361EE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "notification": {
      "icon": "./assets/images/icon.png",
      "color": "#4361EE",
      "androidMode": "default"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#4361EE",
          "defaultChannel": "messages",
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#4361EE",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ChatApp needs access to your photos to share images in chat.",
          "cameraPermission": "ChatApp needs camera access to take photos and videos.",
          "microphonePermission": "ChatApp needs microphone access to record videos."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "expo-video",
      "expo-audio",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          },
          "ios": {
            "deploymentTarget": "16.4"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6bf07534-be49-48c3-b405-ec7d948ec3df"
      }
    },
    "owner": "june2000"
  }
}
